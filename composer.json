{
    "name": "sumaiazaman/laravel-stringable-extras",
    "description": "Missing whenDoesntContain and whenDoesntContainAll methods for Laravel's Stringable class.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sumaiya Zaman",
            "email": "saktar50.cse@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Sumaiazaman\\StringableExtras\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sumaiazaman\\StringableExtras\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sumaiazaman\\StringableExtras\\StringableExtrasServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
